{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "meson configure",
            "type": "shell",
            "command": "meson",
            "args": [
                "setup",
                "build",
                "--buildtype=debug",
                "--werror",
                "-Ddefault_library=static",
                "-Db_sanitize=address,undefined"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "meson compile",
            "type": "shell",
            "command": "ninja",
            "args": [
                "-C",
                "build"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "meson configure"
        },
        {
            "label": "meson rebuild",
            "type": "shell",
            "command": "ninja",
            "args": [
                "-C",
                "build",
                "clean",
                "all"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}